# One-API / OpenAI 兼容接口配置（用于 LLM 对话）
OPENAI_API_KEY=
OPENAI_API_BASE=
OPENAI_MODEL=qwen-plus

# 千问 Embedding 配置（OpenAI 兼容模式，通过 One-API 转发）
EMBEDDING_API_KEY=
EMBEDDING_API_BASE=
EMBEDDING_MODEL=text-embedding-v2

# Milvus 连接配置（线上部署版本）
MILVUS_HOST=
MILVUS_PORT=19530
MILVUS_USER=
MILVUS_PASSWORD=
MILVUS_COLLECTION=

# 文本分割参数
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# MySQL 数据库（远程服务器）
MYSQL_URL=

# JWT 配置
JWT_SECRET=
JWT_EXPIRE_MINUTES=1440
